# GraphQL Meter — Environment Configuration
# Copy to .env and modify as needed

# Server
HOST=0.0.0.0
PORT=8899
DEBUG=false

# Database
DB_PATH=backend/data/portal.db

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY_HOURS=24

# Load Testing
MAX_CONCURRENT_RUNS=3
STATS_POLL_INTERVAL_SEC=2
MAX_ERROR_BUFFER=500
MAX_RUN_HISTORY=200

# k6 Binary Path (auto-detected if empty)
K6_BINARY_PATH=

# Azure AD (optional — for OAuth2 token-based auth to target APIs)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SCOPE=
