# GraphQL Meter — Environment Configuration
# Copy to .env and modify as needed

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8899
DEBUG=false

# ── Database ────────────────────────────────────────────────
DB_PATH=backend/data/portal.db

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY_HOURS=24

# ── Encryption ──────────────────────────────────────────────
# Used for encrypting auth provider secrets at rest.
# Auto-derived from JWT_SECRET if left empty.
ENCRYPTION_KEY=

# ── Load Testing ────────────────────────────────────────────
MAX_CONCURRENT_RUNS=3
STATS_POLL_INTERVAL_SEC=2
MAX_ERROR_BUFFER=500
MAX_RUN_HISTORY=200
CHART_HISTORY_RUNS=10

# ── Engine Toggles ──────────────────────────────────────────
# Set to false to disable an engine entirely (hides from UI).
ENABLE_K6=true
ENABLE_LOCUST=true

# ── Thread / Performance Tuning ─────────────────────────────
WORKER_THREADS=4
UVICORN_WORKERS=1

# ── k6 Binary ──────────────────────────────────────────────
# Leave empty for auto-detection / auto-download.
K6_BINARY_PATH=

# ── Polling Intervals (frontend hints) ──────────────────────
DASHBOARD_POLL_SEC=5
RUNNING_TEST_POLL_SEC=2

# ── Azure AD (optional — OAuth2 token-based auth) ──────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SCOPE=
